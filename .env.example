# --- Server ---
PORT=8080

# --- Database (MySQL) ---
DB_URL=jdbc:mysql://localhost:3306/ticket_booking
DB_USERNAME=root
DB_PASSWORD=your_db_password

# --- JWT ---
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_EXPIRATION_MS=86400000

# --- Seat hold / waitlist TTLs ---
SEAT_HOLD_TTL_MINUTES=10
SEAT_HOLD_CLEANUP_MS=30000
WAITLIST_OFFER_TTL_MINUTES=15

# --- Email (any free-tier SMTP, e.g. Gmail with an App Password) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=your_email@gmail.com

# --- Frontend ---
FRONTEND_BASE_URL=http://localhost:5173
